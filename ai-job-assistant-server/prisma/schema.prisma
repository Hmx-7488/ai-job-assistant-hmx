generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Resume {
  id        String     @id @default(cuid())
  fileName  String
  text      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  analyses  Analysis[]

  @@map("resumes")
}

model Job {
  id          String     @id @default(cuid())
  jobTitle    String
  companyName String?
  jdText      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  analyses    Analysis[]

  @@map("jobs")
}

model Analysis {
  id          String   @id @default(cuid())
  jobId       String
  resumeId    String
  score       Int
  strengths   Json
  weaknesses  Json
  suggestions Json
  rawResult   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([resumeId])
  @@map("analyses")
}
